<bx:setting showdebugoutput="false" >
<!--- CPU Integration --->
<bx:param name="url.cpu" default="false">
<!--- SETUP THE ROOTS OF THE BROWSER RIGHT HERE --->
<bx:set rootMapping 	= "/tests/specs">
<bx:if directoryExists( rootMapping )>
	<bx:set rootPath = rootMapping>
<bx:else>
	<bx:set rootPath = expandPath( rootMapping )>
</bx:if>

<!--- param incoming --->
<bx:param name="url.path" default="/">

<!--- Decodes & Path Defaults --->
<bx:if !len( url.path )>
	<bx:set url.path = "/">
</bx:if>

<!--- Prepare TestBox --->
<bx:set testbox = new testbox.system.TestBox()>

<!--- Run Tests Action?--->
<bx:if structKeyExists( url, "action")>
	<bx:if directoryExists( expandPath( rootMapping & url.path ) )>
		<bx:output>#testbox.init( directory=rootMapping & url.path ).run()#</bx:output>
	<bx:else>
		<bx:output><h2>Invalid incoming directory: #rootMapping & url.path#</h2></bx:output>
	</bx:if>
	<bx:abort>

</bx:if>

<!--- Get list of files --->
<bx:directory action="list" directory="#rootPath & url.path#" name="qResults" sort="directory asc, name asc">
<!--- Get the execute path --->
<bx:set executePath = rootMapping & ( url.path eq "/" ? "/" : url.path & "/" )>
<!--- Get the Back Path --->
<bx:if url.path neq "/">
	<bx:set backPath = replacenocase( url.path, listLast( url.path, "/" ), "" )>
	<bx:set backPath = reReplace( backpath, "/$", "" )>
</bx:if>

<bx:set ASSETS_DIR = expandPath( "/testbox/system/reports/assets" )>
<!--- Do HTML --->
<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="generator" content="TestBox v#testbox.getVersion()#">
	<title>TestBox Browser</title>
	<bx:output>
		<style>#fileRead( '#ASSETS_DIR#/css/main.css' )#</style>
		<script>#fileRead( '#ASSETS_DIR#/js/jquery-3.3.1.min.js' )#</script>
		<script>#fileRead( '#ASSETS_DIR#/js/popper.min.js' )#</script>
		<script>#fileRead( '#ASSETS_DIR#/js/bootstrap.min.js' )#</script>
		<script>#fileRead( '#ASSETS_DIR#/js/stupidtable.min.js' )#</script>
	</bx:output>

</head>
<bx:output>
<body>

<!--- Title --->
<div id="tb-runner" class="container">
	<div class="row">
		<div class="col-md-4 text-center mx-auto">
			<img class="mt-3" src="http://www.ortussolutions.com/__media/testbox-185.png" alt="TestBox" id="tb-logo"/>
			<br>
			v#testbox.getVersion()#
			<br>
			<a href="index.bxm?action=runTestBox&path=#URLEncodedFormat( url.path )#" target="_blank"><button class="btn btn-primary btn-sm my-1" type="button">Run All</button></a>
		</div>
	</div>
	<div class="row">
		<div class="col-md-12">
			<form name="runnerForm" id="runnerForm">
				<input type="hidden" name="opt_run" id="opt_run" value="true">
				<h2>TestBox Test Browser: </h2>
				<p>
					Below is a listing of the files and folders starting from your root <code>#rootPath#</code>.  You can click on individual tests in order to execute them
					or click on the <strong>Run All</strong> button on your left and it will execute a directory runner from the visible folder.
				</p>

				<fieldset>
					<legend>Contents: #executePath#</legend>
					<bx:if url.path neq "/">
						<a href="index.bxm?path=#URLEncodedFormat( backPath )#"><button type="button" class="btn btn-secondary btn-sm my-1">« Back</button></a><br><hr>
					</bx:if>
					<bx:loop query="qResults">
						<bx:if refind( "^\.", qResults.name )>
							<bx:continue>
						</bx:if>

						<bx:set dirPath = URLEncodedFormat( ( url.path neq '/' ? '#url.path#/' : '/' ) & qResults.name )>
                        <bx:set ext = listLast( qResults.name, "." )>
						<bx:if qResults.type eq "Dir">
							<a class="btn btn-secondary btn-sm my-1" href="index.bxm?path=#dirPath#">✚ #qResults.name#</a><br/>
						<bx:elseif ext eq "bxm" or ext eq "cfm">
							<a class="btn btn-primary btn-sm my-1" href="#executePath & qResults.name#" <bx:if !url.cpu>target="_blank"</bx:if>>#qResults.name#</a><br/>
						<bx:elseif ( ext eq "bx" or ext eq "cfc" ) and qResults.name neq "Application.bx" and qResults.name neq "Application.cfc">
							<a class="btn btn-primary btn-sm my-1" href="#executePath & qResults.name#?method=runRemote" <bx:if !url.cpu>target="_blank"</bx:if>>#qResults.name#</a><br/>
						<bx:else>
							#qResults.name#<br/>
						</bx:if>

					</bx:loop>
				</fieldset>
			</form>
		</div>
	</div>
</div>

</body>
</html>
</bx:output>
