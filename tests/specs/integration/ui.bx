class extends="testbox.system.BaseSpec" {

    // Test configuration
    property name="baseURL" default="http://localhost:8081";

    property name="testCredentials" default={
        "valid": {
            "email": "jramirez@ortussolutions.com",
            "password": "mUjze3-xyqhom-kewhew@"
        },
        "invalid": {
            "email": "invalid@example.com", 
            "password": "wrongpassword"
        }
    };
    
    // Page selectors
    property name="selectors" default = {
        "emailInput": "input[type='email']",
        "passwordInput": "input[type='password']", 
        "loginButton": "button[id='loginButton']",
        "submitButton": "button[type='submit'], button:has-text('Login'), button:has-text('Sign In')"
    };
    
    // Shared test state
    property name="playwright";
    property name="browser";
    property name="page";

    function run(){

        describe( "Login Page Integration Tests", () => {
            
            beforeEach( () => {
                // Setup Playwright for each test with visible browser
                variables.playwright = createObject( "java", "com.microsoft.playwright.Playwright" ).create();
                
                // Create browser launch options to make it visible
                var BrowserType = createObject( "java", "com.microsoft.playwright.BrowserType$LaunchOptions" );

                var launchOptions = BrowserType.init()
                    .setHeadless( false )        // Show browser window
                    .setSlowMo( 2000 );          // Slow down actions by 2 seconds
                
                variables.browser = variables.playwright.chromium().launch( launchOptions );

                variables.page = variables.browser.newPage();
                
                navigateTo( "/login" );
            });
            
            afterEach( () => {
                // Clean up browser resources
                if ( structKeyExists( variables, "browser" ) ) {
                    variables.browser.close();
                }
            });
            
            describe( "Login functionality", () => {
            
                it( "should load login page with correct title", () => { 
                    expect( variables.page.title() ).toInclude( "TIMEBOX" );
                } ); 

                it( "should display login form elements", () => {
                    // Check for login form elements
                    expect( variables.page.locator( variables.selectors.emailInput ).first().isVisible() ).toBeTrue();
                    expect( variables.page.locator( variables.selectors.passwordInput ).first().isVisible() ).toBeTrue();
                    expect( variables.page.locator( variables.selectors.submitButton ).first().isVisible() ).toBeTrue();
                } );

                it( "should handle invalid login credentials", () => {
                    // Fill in invalid credentials and attempt login
                    fillLoginForm( variables.testCredentials.invalid.email, variables.testCredentials.invalid.password );
                    submitLoginForm();
                    
                    // Wait and verify still on login page
                    variables.page.waitForTimeout( 2000 );
                    expect( variables.page.url() ).toInclude( "/login" );
                } );

                it( "should handle empty credentials validation", () => {
                    // Try to submit without filling credentials
                    clickLoginButton();
                    
                    // Should stay on login page
                    expect( variables.page.url() ).toInclude( "/login" );
                } );

                it( "should mask password input", () => {
                    // Check password field type
                    var passwordField = variables.page.locator( variables.selectors.passwordInput ).first();
                    expect( passwordField.getAttribute( "type" ) ).toBe( "password" );
                } );

                it( "should handle valid login and redirect", () => {
                    // Fill in valid credentials and login
                    fillLoginForm( variables.testCredentials.valid.email, variables.testCredentials.valid.password );
                    clickLoginButton();
                    
                    // Wait for redirect and verify
                    variables.page.waitForTimeout( 3000 );
                    expect( variables.page.url() ).toInclude( "/dashboard" );
                } );

            } );

        } );
    }
    
    // Helper methods for maintainable tests
    private function navigateTo( to = "/login" ) {
        variables.page.navigate( variables.baseURL & arguments.to );
    }
    
    private function fillLoginForm( required string email, required string password ) {
        variables.page.fill( variables.selectors.emailInput, arguments.email );
        variables.page.fill( variables.selectors.passwordInput, arguments.password );
    }
    
    private function submitLoginForm() {
        variables.page.click( variables.selectors.submitButton );
    }
    
    private function clickLoginButton() {
        variables.page.click( variables.selectors.loginButton );
    }

}