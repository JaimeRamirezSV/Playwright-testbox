/**
 * Example test demonstrating BaseTestService + BaseTest usage.
 *
 * Extends BaseTest for shared config (credentials, selectors, browser defaults)
 * and uses BaseTestService for fluent Playwright interactions.
 */
class extends="tests.resources.BaseSpec" {

	property name="ui";

	function run() {

		forEachBrowser( "Login Page Tests", ( browserName ) => {

			beforeEach( () => {
				variables.ui = createUI( browserName );
				variables.ui.goTo( "/login" );
			} );

			afterEach( () => {
				variables.ui.close();
			} );


			it( "should load the login page with correct title", () => {
				expect( variables.ui.getTitle() ).toInclude( "TIMEBOX" );
			} ); 

		} );

	}

}
