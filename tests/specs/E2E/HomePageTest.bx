/**
 * Home Page Tests
 *
 * Tests for the main index.bxm page: header, form submission, toggle,
 * counter, data table, hover interaction, and drag-and-drop.
 */
class extends="tests.resources.BaseSpec" {

	property name="ui";

	function run() {

        variables.browserDefaults = {
            "headless": true, // set to false to see the browser during testing
            "slowMo"  : 0 // set 500 for slow motion to visually see the tests running
        };

        variables.browsers = [ "chromium", "firefox", "webkit" ];

		forEachBrowser( "Home Page Tests", ( browserName ) => {

			beforeEach( () => {
				variables.ui = createUI( browserName );
				variables.ui.goTo( "/index.bxm" );
			} );

			afterEach( () => {
				variables.ui.close();
			} );

			// ----- Page Load & Header -----

			it( "should load the home page with correct title", () => {
				expect( variables.ui.getTitle() ).toInclude( "BoxLang Test Page" );
			} );

			it( "should display the page heading", () => {
				expect( variables.ui.isVisible( "##page-title" ) ).toBeTrue();
				expect( variables.ui.getText( "##page-title" ) ).toBe( "BoxLang Test Page" );
			} );

			it( "should display the welcome message", () => {
				expect( variables.ui.isVisible( "##welcome-message" ) ).toBeTrue();
				expect( variables.ui.getText( "##welcome-message" ) ).toInclude( "Playwright end-to-end testing" );
			} );

			// ----- Navigation -----

			it( "should show all navigation links", () => {
				expect( variables.ui.isVisible( "##nav-home" ) ).toBeTrue();
				expect( variables.ui.isVisible( "##nav-about" ) ).toBeTrue();
				expect( variables.ui.isVisible( "##nav-contact" ) ).toBeTrue();
			} );

			it( "should have Home link as active", () => {
				expect( variables.ui.getAttribute( "##nav-home", "class" ) ).toInclude( "active" );
			} );

			// ----- Contact Form -----

			it( "should display the contact form", () => {
				expect( variables.ui.isVisible( "##contact-form-section" ) ).toBeTrue();
				expect( variables.ui.isVisible( "##name" ) ).toBeTrue();
				expect( variables.ui.isVisible( "##email" ) ).toBeTrue();
				expect( variables.ui.isVisible( "##message" ) ).toBeTrue();
				expect( variables.ui.isVisible( "##category" ) ).toBeTrue();
				expect( variables.ui.isVisible( "##submit-btn" ) ).toBeTrue();
			} );

			it( "should fill and submit the contact form", () => {
				variables.ui
					.fill( "##name", "John Doe" )
					.fill( "##email", "john@example.com" )
					.fill( "##message", "Hello from Playwright!" )
					.selectOption( "##category", "support" )
					.check( "##priority-high" )
					.check( "##agree" )
					.click( "##submit-btn" );

				expect( variables.ui.isVisible( "##form-result" ) ).toBeTrue();
				expect( variables.ui.hasText( "##form-result", "Thank you, John Doe" ) ).toBeTrue();
			} );

			it( "should select a category from the dropdown", () => {
				variables.ui.selectOption( "##category", "feedback" );
				// Verify the select has the right value by checking the page state
				var page = variables.ui.getPage();
				var selectedValue = page.locator( "##category" ).inputValue();
				expect( selectedValue ).toBe( "feedback" );
			} );

			it( "should check and uncheck the terms checkbox", () => {
				variables.ui.check( "##agree" );
				var page = variables.ui.getPage();
				expect( page.locator( "##agree" ).isChecked() ).toBeTrue();

				variables.ui.uncheck( "##agree" );
				expect( page.locator( "##agree" ).isChecked() ).toBeFalse();
			} );

			it( "should select a radio button for priority", () => {
				variables.ui.check( "##priority-low" );
				var page = variables.ui.getPage();
				expect( page.locator( "##priority-low" ).isChecked() ).toBeTrue();

				variables.ui.check( "##priority-high" );
				expect( page.locator( "##priority-high" ).isChecked() ).toBeTrue();
				expect( page.locator( "##priority-low" ).isChecked() ).toBeFalse();
			} );

			// ----- Toggle Demo -----

			it( "should toggle content visibility on button click", () => {
				// Content initially hidden
				var page = variables.ui.getPage();
				expect( page.locator( "##toggle-content" ).isVisible() ).toBeFalse();

				// Click to show
				variables.ui.click( "##toggle-btn" );
				expect( variables.ui.isVisible( "##toggle-content" ) ).toBeTrue();
				expect( variables.ui.hasText( "##toggle-text", "hidden details revealed" ) ).toBeTrue();
				expect( variables.ui.getText( "##toggle-btn" ) ).toBe( "Hide Details" );

				// Click to hide again
				variables.ui.click( "##toggle-btn" );
				expect( page.locator( "##toggle-content" ).isVisible() ).toBeFalse();
				expect( variables.ui.getText( "##toggle-btn" ) ).toBe( "Show Details" );
			} );

			// ----- Counter -----

			it( "should start counter at zero", () => {
				expect( variables.ui.getText( "##counter-value" ) ).toBe( "0" );
			} );

			it( "should increment the counter", () => {
				variables.ui.click( "##increment-btn" );
				expect( variables.ui.getText( "##counter-value" ) ).toBe( "1" );

				variables.ui.click( "##increment-btn" );
				expect( variables.ui.getText( "##counter-value" ) ).toBe( "2" );
			} );

			it( "should decrement the counter", () => {
				variables.ui.click( "##decrement-btn" );
				expect( variables.ui.getText( "##counter-value" ) ).toBe( "-1" );
			} );

			it( "should increment and decrement sequentially", () => {
				variables.ui.click( "##increment-btn" );
				variables.ui.click( "##increment-btn" );
				variables.ui.click( "##increment-btn" );
				variables.ui.click( "##decrement-btn" );
				expect( variables.ui.getText( "##counter-value" ) ).toBe( "2" );
			} );

			// ----- Data Table -----

			it( "should display the users table", () => {
				expect( variables.ui.isVisible( "##users-table" ) ).toBeTrue();
			} );

			it( "should show correct table headers", () => {
				expect( variables.ui.hasText( "##users-table thead", "ID" ) ).toBeTrue();
				expect( variables.ui.hasText( "##users-table thead", "Name" ) ).toBeTrue();
				expect( variables.ui.hasText( "##users-table thead", "Role" ) ).toBeTrue();
			} );

			it( "should display all user rows", () => {
				var page = variables.ui.getPage();
				var rowCount = page.locator( "##users-table tbody tr" ).count();
				expect( rowCount ).toBe( 3 );
			} );

			it( "should show correct user data", () => {
				expect( variables.ui.hasText( "##users-table", "Alice" ) ).toBeTrue();
				expect( variables.ui.hasText( "##users-table", "Bob" ) ).toBeTrue();
				expect( variables.ui.hasText( "##users-table", "Charlie" ) ).toBeTrue();
			} );

			it( "should show role badges", () => {
				expect( variables.ui.hasText( "##users-table", "Admin" ) ).toBeTrue();
				expect( variables.ui.hasText( "##users-table", "Editor" ) ).toBeTrue();
				expect( variables.ui.hasText( "##users-table", "Viewer" ) ).toBeTrue();
			} );

			// ----- Hover Demo -----

			it( "should show message on hover", () => {
				var page = variables.ui.getPage();
				// Initially hidden
				expect( page.locator( "##hover-result" ).isVisible() ).toBeFalse();

				// Hover to reveal
				variables.ui.hover( "##hover-target" );
				expect( variables.ui.isVisible( "##hover-result" ) ).toBeTrue();
				expect( variables.ui.hasText( "##hover-result", "You hovered!" ) ).toBeTrue();
			} );

			// ----- Drag and Drop -----

			it( "should display drag source and drop target", () => {
				expect( variables.ui.isVisible( "##drag-source" ) ).toBeTrue();
				expect( variables.ui.isVisible( "##drop-target" ) ).toBeTrue();
				expect( variables.ui.hasText( "##drag-source", "Drag me" ) ).toBeTrue();
				expect( variables.ui.hasText( "##drop-target", "Drop here" ) ).toBeTrue();
			} );

			it( "should complete a drag and drop operation", () => {
				variables.ui.dragAndDrop( "##drag-source", "##drop-target" );
				expect( variables.ui.hasText( "##drop-target", "Dropped!" ) ).toBeTrue();
				expect( variables.ui.getAttribute( "##drop-target", "class" ) ).toInclude( "dropped" );
			} );

		} );

	}

}
