/**
 * Login Page E2E Tests
 *
 * Tests for /pages/login.bxm: page rendering, form validation,
 * invalid credentials, successful login, and logout flow.
 * Uses Playwright role-based selectors (getByRole, getByLabel).
 */
class extends="tests.resources.BaseSpec" {

	function run() {

		describe( "Login Page", function() {

			variables.browserDefaults = {
				"headless": false,
				"slowMo"  : 500
			};

			variables.browsers = [ "webkit", /* "chromium", "firefox" */ ];

			variables.device = "iPad Pro 11";

			forEachBrowser( "Login Page Tests", ( browserName ) => {

				beforeEach( () => {
					variables.ui = createUI( browserName );
				} );

				afterEach( () => {
					variables.ui.close();
				} );

				it( "should display the login form", () => {
					goTo( "/pages/login.bxm" );
					var loginForm = variables.page.getByRole( ariaRole( "form" ), roleOpts( "Login form" ) );
					expect( loginForm.isVisible() ).toBeTrue();
				} );

				it( "should prevent submission with empty fields (HTML validation)", () => {
					goTo( "/pages/login.bxm" );
					var submitButton = variables.page.getByRole( ariaRole( "button" ), roleOpts( "Sign In" ) );
					submitButton.click();
					expect( variables.page.url() ).toInclude( "/pages/login.bxm" );
					var isInvalid = variables.page.evaluate( "document.getElementById('login-username').validity.valueMissing" );
					expect( isInvalid ).toBeTrue();
				} );

				it( "should login successfully with valid credentials", () => {
					goTo( "/pages/login.bxm" );
					variables.page.getByLabel( "Username" ).fill( "admin" );
					variables.page.getByLabel( "Password" ).fill( "admin123" );
					variables.page.getByRole( ariaRole( "button" ), roleOpts( "Sign In" ) ).click();
					expect( variables.page.url() ).toInclude( "/pages/todos.bxm" );
					// Verify the welcome toast popup
					var toast = variables.page.getByRole( ariaRole( "status" ) );
					expect( toast.isVisible() ).toBeTrue();
					expect( toast.textContent() ).toInclude( "Welcome back, admin" );
				} );

			} );

		} );

	}

}
