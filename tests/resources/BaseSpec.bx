/**
 * BaseSpec - Shared test configuration and Playwright integration for all E2E tests.
 *
 * Centralises host URLs, credentials, browser settings, and Playwright browser
 * lifecycle so individual test specs stay focused on behaviour, not setup data.
 * Extend this class instead of testbox.system.BaseSpec in your test files.
 */
class extends="testbox.system.BaseSpec" {

	// ---------------------------------------------------------------------------
	// Host / Environment
	// ---------------------------------------------------------------------------

	property name="baseURL" default="http://localhost:8080";

	// ---------------------------------------------------------------------------
	// Playwright Instances
	// ---------------------------------------------------------------------------

	property name="playwright";
	property name="browser";
	property name="page";

	// ---------------------------------------------------------------------------
	// Browser Defaults
	// ---------------------------------------------------------------------------

	property name="browserDefaults" default={
		"headless": true,
		"slowMo"  : 0
	};

	/** Browsers to run every test suite against. */
	property name="browsers" default=[ "chromium", "firefox", "webkit" ];

	property name="device" default="";

	// ---------------------------------------------------------------------------
	// Helpers
	// ---------------------------------------------------------------------------

	/**
	 * Create a Playwright UI session pre-configured with the shared settings.
	 * Launches a browser, opens a new page, and returns this instance
	 * so callers can use variables.page directly.
	 *
	 * @browser  Override the browser engine for this instance (e.g. "firefox").
	 * @return   BaseSpec (fluent) — access the page via variables.page.
	 */
	function createUI( string browser = "chromium" ) {
		variables.playwright = createObject( "java", "com.microsoft.playwright.Playwright" ).create();

		var launchOptions = createObject( "java", "com.microsoft.playwright.BrowserType$LaunchOptions" )
			.init()
			.setHeadless( variables.browserDefaults.headless )
			.setSlowMo( variables.browserDefaults.slowMo );

		switch ( arguments.browser ) {
			case "firefox":
				variables.browser = variables.playwright.firefox().launch( launchOptions );
				break;
			case "webkit":
				variables.browser = variables.playwright.webkit().launch( launchOptions );
				break;
			default:
				variables.browser = variables.playwright.chromium().launch( launchOptions );
		}

		// If a device is set, create a context with device emulation
		if ( len( variables.device ) ) {
			var d = getDevicePreset( variables.device );
			var contextOptions = createObject( "java", "com.microsoft.playwright.Browser$NewContextOptions" )
				.init()
				.setUserAgent( d.userAgent )
				.setViewportSize( d.width, d.height )
				.setDeviceScaleFactor( d.scaleFactor )
				.setHasTouch( d.hasTouch );

			// Firefox does not support the isMobile context option.
			if ( arguments.browser != "firefox" ) {
				contextOptions.setIsMobile( d.isMobile );
			}

			variables.context = variables.browser.newContext( contextOptions );
			variables.page = variables.context.newPage();
		} else {
			variables.page = variables.browser.newPage();
		}

		return this;
	}

	/**
	 * Navigate to a path, prepending the baseURL.
	 *
	 * @path  The relative URL path (e.g. "/index.bxm").
	 */
	function goTo( required string path ) {
		try {
			variables.page.navigate( variables.baseURL & arguments.path );
		} catch ( any e ) {
			// If navigation fails (e.g., host unavailable), close resources immediately.
			close();
			rethrow;
		}
		return this;
	}

	/**
	 * Get a device preset for emulation.
	 *
	 * @deviceName  Device name (e.g. "iPhone 14", "Pixel 7", "iPad Pro 11").
	 * @return      Struct with userAgent, width, height, scaleFactor, isMobile, hasTouch.
	 */
	function getDevicePreset( required string deviceName ) {
		var devices = {
			"iPhone 14": {
				userAgent: "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1",
				width: 390, height: 844, scaleFactor: 3, isMobile: true, hasTouch: true
			},
			"iPhone 14 Pro Max": {
				userAgent: "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1",
				width: 430, height: 932, scaleFactor: 3, isMobile: true, hasTouch: true
			},
			"iPhone 13": {
				userAgent: "Mozilla/5.0 (iPhone; CPU iPhone OS 15_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/15.0 Mobile/15E148 Safari/604.1",
				width: 390, height: 844, scaleFactor: 3, isMobile: true, hasTouch: true
			},
			"Pixel 7": {
				userAgent: "Mozilla/5.0 (Linux; Android 13; Pixel 7) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/116.0.0.0 Mobile Safari/537.36",
				width: 412, height: 915, scaleFactor: 2.625, isMobile: true, hasTouch: true
			},
			"Galaxy S9+": {
				userAgent: "Mozilla/5.0 (Linux; Android 8.0.0; SM-G965U) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/116.0.0.0 Mobile Safari/537.36",
				width: 320, height: 658, scaleFactor: 4.5, isMobile: true, hasTouch: true
			},
			"iPad Pro 11": {
				userAgent: "Mozilla/5.0 (iPad; CPU OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1",
				width: 834, height: 1194, scaleFactor: 2, isMobile: true, hasTouch: true
			}
		};

		if ( !structKeyExists( devices, arguments.deviceName ) ) {
			throw( message="Unknown device preset: #arguments.deviceName#. Available: #structKeyList( devices )#" );
		}
		return devices[ arguments.deviceName ];
	}

	/**
	 * Close the browser and Playwright instance.
	 * Safe to call multiple times — variables are nulled after closing.
	 */
	function close() {
		if ( !isNull( variables.page ) ) {
			variables.page.close();
			variables.page = nullValue();
		}
		if ( !isNull( variables.context ) ) {
			variables.context.close();
			variables.context = nullValue();
		}
		if ( !isNull( variables.browser ) ) {
			variables.browser.close();
			variables.browser = nullValue();
		}
		if ( !isNull( variables.playwright ) ) {
			variables.playwright.close();
			variables.playwright = nullValue();
		}
	}


	/**
	 * Get the AriaRole enum value for Playwright's getByRole().
	 *
	 * @role  The role name (e.g. "heading", "button", "form", "link", "alert", "banner", "dialog", "navigation", "main", "region").
	 * @return java AriaRole enum value
	 */
	function ariaRole( required string role ) {
		var AriaRole = createObject( "java", "com.microsoft.playwright.options.AriaRole" );
		switch ( arguments.role ) {
			case "alert":       return AriaRole.ALERT;
			case "banner":      return AriaRole.BANNER;
			case "button":      return AriaRole.BUTTON;
			case "dialog":      return AriaRole.DIALOG;
			case "form":        return AriaRole.FORM;
			case "heading":     return AriaRole.HEADING;
			case "link":        return AriaRole.LINK;
			case "list":        return AriaRole.LIST;
			case "listitem":    return AriaRole.LISTITEM;
			case "main":        return AriaRole.MAIN;
			case "navigation":  return AriaRole.NAVIGATION;
			case "region":      return AriaRole.REGION;
			case "status":      return AriaRole.STATUS;
			case "textbox":     return AriaRole.TEXTBOX;
			default:            throw( message="Unknown AriaRole: #arguments.role#" );
		}
	}

	/**
	 * Create a GetByRoleOptions object with the given name filter.
	 *
	 * @name  The accessible name to match.
	 * @return java Page.GetByRoleOptions
	 */
	function roleOpts( required string name ) {
		return createObject( "java", "com.microsoft.playwright.Page$GetByRoleOptions" )
			.init()
			.setName( arguments.name );
	}

	/**
	 * Run a block of specs once per browser engine.
	 *
	 * Usage inside run():
	 *   forEachBrowser( "Login Tests", ( browserName ) => {
	 *       beforeEach( () => { variables.ui = createUI( browserName ); ... } );
	 *       it( "should ...", () => { ... } );
	 *   } );
	 *
	 * This generates a describe() per browser so results are grouped:
	 *   [chromium] Login Tests
	 *   [firefox]  Login Tests
	 *   [webkit]   Login Tests
	 *
	 * @label  Suite label for the describe block.
	 * @specs  Closure that receives the browser name as its single argument.
	 */
	function forEachBrowser( required string label, required function specs ) {
		var suiteLabel = label;
		var suiteSpecs = specs;

		Println( "Running suite: #suiteLabel# for browsers: #arrayToList( variables.browsers )#" );

		for ( var browserName in variables.browsers ) {
			describe( "[#browserName#] #suiteLabel#", () => {
				suiteSpecs( browserName );
			} );
		}
	}

}
