/**
 * BaseTest - Shared test configuration for all integration tests.
 *
 * Centralises host URLs, credentials, selectors, and browser settings
 * so individual test specs stay focused on behaviour, not setup data.
 * Extend this class instead of testbox.system.BaseSpec in your test files.
 */
class extends="testbox.system.BaseSpec" {

	// ---------------------------------------------------------------------------
	// Host / Environment
	// ---------------------------------------------------------------------------

	property name="baseURL" default="http://localhost:8080";

	// ---------------------------------------------------------------------------
	// Credentials
	// ---------------------------------------------------------------------------

	property name="testCredentials" default={
		"valid": {
			"email"   : "jramirez@ortussolutions.com",
			"password": "mUjze3-xyqhom-kewhew@"
		},
		"invalid": {
			"email"   : "invalid@example.com",
			"password": "wrongpassword"
		}
	};

	// ---------------------------------------------------------------------------
	// Common Selectors
	// ---------------------------------------------------------------------------

	property name="selectors" default={
		"emailInput"   : "input[type='email']",
		"passwordInput": "input[type='password']",
		"loginButton"  : "button[id='loginButton']",
		"submitButton" : "button[type='submit'], button:has-text('Login'), button:has-text('Sign In')"
	};

	// ---------------------------------------------------------------------------
	// Browser Defaults
	// ---------------------------------------------------------------------------

	property name="browserDefaults" default={
		"headless": false,
		"slowMo"  : 500
	};

	/** Browsers to run every test suite against. */
	property name="browsers" default=[ "chromium", "firefox", "webkit" ];

	// ---------------------------------------------------------------------------
	// Helpers
	// ---------------------------------------------------------------------------

	/**
	 * Create a PlaywrightService pre-configured with the shared settings.
	 *
	 * @browser  Override the browser engine for this instance (e.g. "firefox").
	 */
	function createUI( string browser = "chromium" ) {
		return new tests.resources.PlaywrightService(
			baseURL  = variables.baseURL,
			headless = variables.browserDefaults.headless,
			slowMo   = variables.browserDefaults.slowMo,
			browser  = arguments.browser
		);
	}

	/**
	 * Run a block of specs once per browser engine.
	 *
	 * Usage inside run():
	 *   forEachBrowser( ( browserName ) => {
	 *       beforeEach( () => { variables.ui = createUI( browserName ); ... } );
	 *       it( "should ...", () => { ... } );
	 *   } );
	 *
	 * This generates a describe() per browser so results are grouped:
	 *   [chromium] Login Tests
	 *   [firefox]  Login Tests
	 *   [webkit]   Login Tests
	 *
	 * @label    Optional suite label. Defaults to "Cross-browser tests".
	 * @body     Closure that receives the browser name as its single argument.
	 */
	function forEachBrowser( required string label, required function specs ) {
		var suiteLabel = label;
		var suiteSpecs = specs;
		for ( var browserName in variables.browsers ) {
			describe( "[#browserName#] #suiteLabel#", () => {
				suiteSpecs( browserName );
			} );
		}
	}

}
